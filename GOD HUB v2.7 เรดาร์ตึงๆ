local function applyLockOnHighlight(obj)
    if not obj then return end
    local targetPart = obj
    if obj:IsA("ProximityPrompt") or obj:IsA("TouchTransmitter") then targetPart = obj.Parent end
    if not targetPart or not (targetPart:IsA("BasePart") or targetPart:IsA("Model")) then return end
    if targetPart:FindFirstChild("GodHighlight") then return end
    pcall(function()
        local hl = Instance.new("Highlight", targetPart)
        hl.Name, hl.FillColor, hl.OutlineColor = "GodHighlight", Color3.fromRGB(0, 255, 100), Color3.fromRGB(255, 255, 255)
        hl.FillTransparency = 0.4
        task.delay(0.8, function() if hl then hl:Destroy() end end)
    end)
end

