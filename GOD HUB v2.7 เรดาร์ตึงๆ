local function createFullBtn(yPos, text, activeColor, callback)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Size, btn.Position, btn.BackgroundColor3 = UDim2.new(1, -40, 0, 35), UDim2.new(0, 20, 0, yPos), Color3.fromRGB(45, 45, 55)
    btn.Text, btn.TextColor3, btn.Font, btn.TextSize = text, Color3.fromRGB(200, 200, 200), Enum.Font.GothamMedium, 13
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    local isActive = false
    btn.MouseButton1Click:Connect(function()
        isActive = not isActive
        if isActive then btn.BackgroundColor3, btn.TextColor3, btn.Text = activeColor, Color3.new(1,1,1), text.." [ ON ]"
        else btn.BackgroundColor3, btn.TextColor3, btn.Text = Color3.fromRGB(45,45,55), Color3.fromRGB(200,200,200), text end
        if callback then callback(isActive) end
    end)
end

createFullBtn(60, "🧹 1. Smart Filter (Clear Junk)", Color3.fromRGB(0, 150, 255), function(state)
    isFilterOn = state
    if isFilterOn then
        for _, obj in pairs(Workspace:GetDescendants()) do
            if table.find(junkClasses, obj.ClassName) then pcall(function() obj:Destroy() end) end
        end
    end
end)

createFullBtn(105, "📡 2. Live Radar", Color3.fromRGB(255, 150, 0), function(state)
    isRadarOn = state
