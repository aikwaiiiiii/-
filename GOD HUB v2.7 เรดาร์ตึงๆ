local isFilterOn, isRadarOn, isAutoLoop, isTargetFarm = false, false, false, false
local junkClasses = {"ParticleEmitter", "Decal", "Texture", "Trail", "Sparkles", "Fire", "Smoke", "Atmosphere"}

local function notify(msg)
    pcall(function() StarterGui:SetCore("SendNotification", {Title = "👑 GOD HUB", Text = msg, Duration = 2.5}) end)
end

local function getRoot() return lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") end

local function applyLockOnHighlight(obj)
    if not isRadarOn or not obj then return end
    local targetPart = obj
    if obj:IsA("ProximityPrompt") or obj:IsA("TouchTransmitter") then targetPart = obj.Parent end
    if not targetPart or not (targetPart:IsA("BasePart") or targetPart:IsA("Model")) then return end
    if targetPart:FindFirstChild("GodHighlight") then return end
    
    pcall(function()
        local hl = Instance.new("Highlight", targetPart)
        hl.Name, hl.FillColor, hl.OutlineColor = "GodHighlight", Color3.fromRGB(0, 255, 100), Color3.fromRGB(255, 255, 255)
        hl.FillTransparency = 0.4
        task.delay(0.8, function() if hl then hl:Destroy() end end)
    end)
end

-- 🟢 สมองฝั่งซ้าย: v2.2 ดั้งเดิม (กวาดหมด)
local function isTarget_v22(obj)
    if not obj then return false end
    if obj:IsA("ProximityPrompt") or obj:IsA("TouchTransmitter") then return true end
    if obj.Name then
        local name = string.lower(obj.Name)
        if string.find(name, "loot") or string.find(name, "chest") then
            if obj:IsA("BasePart") or obj:IsA("Model") then return true end
        end
    end
    return false
end

local function collectItem_v22(obj)
    local root = getRoot()
    if not root then return end
    task.spawn(applyLockOnHighlight, obj)
    
    if obj:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(obj) end)
    elseif obj:IsA("TouchTransmitter") and obj.Parent and obj.Parent:IsA("BasePart") then
        pcall(function() firetouchinterest(root, obj.Parent, 0) task.wait(0.01) firetouchinterest(root, obj.Parent, 1) end)
    else
        local touchPart = obj:IsA("BasePart") and obj or (obj:IsA("Model") and obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart"))
        if touchPart then pcall(function() firetouchinterest(root, touchPart, 0) task.wait(0.01) firetouchinterest(root, touchPart, 1) end) end
    end
end

-- 🔴 สมองฝั่งขวา: โหมดแม่เหล็ก Force-Pull (ระบบกระชากเข้าตัว)
local function isCustomTarget(obj)
    if not obj or not obj.Name then return false end
    local text = string.lower(targetInput.Text)
    if text == "" then return false end
    local name = string.lower(obj.Name)
    
    for word in string.gmatch(text, "([^,]+)") do
        word = word:match("^%s*(.-)%s*$")
        if word ~= "" and string.find(name, word) then
            if obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("ProximityPrompt") or obj:IsA("TouchTransmitter") then return true end
        end
    end
    return false
end

local function collectItem_Target(obj)
    local root = getRoot()
    if not root then return end
    task.spawn(applyLockOnHighlight, obj)
    
    pcall(function()
        local targetPart = nil
        if obj:IsA("BasePart") then targetPart = obj
        elseif obj:IsA("Model") then targetPart = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        elseif obj:IsA("TouchTransmitter") and obj.Parent and obj.Parent:IsA("BasePart") then targetPart = obj.Parent
        end
        
        if targetPart then
            targetPart.CFrame = root.CFrame -- แม่เหล็กวาร์ปแร่!
            firetouchinterest(root, targetPart, 0) task.wait(0.01) firetouchinterest(root, targetPart, 1)
        elseif obj:IsA("ProximityPrompt") then
            fireproximityprompt(obj)
        end
    end)
end

