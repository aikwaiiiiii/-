-- โหมดดั้งเดิม
local function isTarget_v22(obj)
    if not obj then return false end
    if obj:IsA("ProximityPrompt") or obj:IsA("TouchTransmitter") then return true end
    if obj.Name then
        local name = string.lower(obj.Name)
        if string.find(name, "loot") or string.find(name, "chest") then
            if obj:IsA("BasePart") or obj:IsA("Model") then return true end
        end
    end
    return false
end

local function collectItem_v22(obj)
    local root = getRoot()
    if not root then return end
    if isRadarOn then task.spawn(applyLockOnHighlight, obj) end
    if obj:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(obj) end)
    elseif obj:IsA("TouchTransmitter") and obj.Parent and obj.Parent:IsA("BasePart") then
        pcall(function() firetouchinterest(root, obj.Parent, 0) task.wait(0.01) firetouchinterest(root, obj.Parent, 1) end)
    else
        local tp = obj:IsA("BasePart") and obj or (obj:IsA("Model") and obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart"))
        if tp then pcall(function() firetouchinterest(root, tp, 0) task.wait(0.01) firetouchinterest(root, tp, 1) end) end
    end
end

-- โหมดแม่เหล็ก Force-Pull
local function isCustomTarget(obj)
    if not obj or not obj.Name then return false end
    local text = string.lower(targetInput.Text)
    if text == "" then return false end
    local name = string.lower(obj.Name)
    for word in string.gmatch(text, "([^,]+)") do
        word = word:match("^%s*(.-)%s*$")
        if word ~= "" and string.find(name, word) then
            if obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("ProximityPrompt") or obj:IsA("TouchTransmitter") then return true end
        end
    end
    return false
end

local function collectItem_Target(obj)
    local root = getRoot()
    if not root then return end
    if isRadarOn then task.spawn(applyLockOnHighlight, obj) end
    pcall(function()
        local tp = nil
        if obj:IsA("BasePart") then tp = obj
        elseif obj:IsA("Model") then tp = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        elseif obj:IsA("TouchTransmitter") and obj.Parent and obj.Parent:IsA("BasePart") then tp = obj.Parent
        end
        if tp then
            tp.CFrame = root.CFrame 
            firetouchinterest(root, tp, 0) task.wait(0.01) firetouchinterest(root, tp, 1)
        elseif obj:IsA("ProximityPrompt") then
            fireproximityprompt(obj)
        end
    end)
end

