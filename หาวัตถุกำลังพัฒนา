-- 6. ENGINE (DEEP SCAN)
local function getDetailedPath(obj)
    local s, r = pcall(function()
        local pParts, curr = {}, obj
        while curr and curr ~= game do table.insert(pParts, 1, curr.Name) curr = curr.Parent end
        return "game." .. table.concat(pParts, ".")
    end)
    return s and r or "Error"
end

local function getFirstModel(obj)
    local c = obj.Parent
    while c and c ~= workspace and c ~= game do
        if c:IsA("Model") then return c end c = c.Parent
    end
    return obj
end

local function analyzeHierarchy(obj, pathStr)
    local txt = "<font color='#00FFAA'><b>[ ข้อมูลโครงสร้างหลัก ]</b></font>\nชื่อ: " .. obj.Name .. "\nประเภท: " .. obj.ClassName .. "\n\n<font color='#AADDFF'>" .. pathStr .. "</font>\n\n"
    local cCount, tHidden = {}, 0
    pcall(function()
        for _, c in ipairs(obj:GetDescendants()) do
            tHidden = tHidden + 1; cCount[c.ClassName] = (cCount[c.ClassName] or 0) + 1
            if tHidden > 1500 then cCount["⚠️ Limit"] = 1 break end
        end
    end)
    if tHidden > 0 then
        txt = txt .. "<font color='#FF55FF'><b>[ ไฟล์แฝง ]</b></font>\n"
        for k, v in pairs(cCount) do txt = txt .. "• " .. k .. ": <font color='#FFAA00'>" .. v .. "</font>\n" end
        txt = txt .. "\n"
    end
    if obj:IsA("BasePart") then
        txt = txt .. "<font color='#00FFAA'><b>[ กายภาพ ]</b></font>\nพิกัด: " .. string.format("%.1f, %.1f, %.1f", obj.Position.X, obj.Position.Y, obj.Position.Z) .. "\n"
    end
    return txt
end

