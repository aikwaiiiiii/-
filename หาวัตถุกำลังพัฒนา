            txt = txt .. "ชื่อ: " .. obj.Name .. " | ประเภท: " .. obj.ClassName .. "\n\n"
            txt = txt .. "<font color='#00FFAA'><b>[ Path ]</b></font>\n<font color='#AADDFF'>" .. currentPathStr .. "</font>\n\n"
            
            if obj:FindFirstChildOfClass("TouchTransmitter") then txt = txt .. "🟢 โต้ตอบแบบ: เดินเหยียบ (Touch)\n" end
            if obj:FindFirstChildOfClass("ProximityPrompt") then txt = txt .. "⌨️ โต้ตอบแบบ: กด E (Proximity)\n" end
