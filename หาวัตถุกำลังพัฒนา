UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe or not frame.Visible then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if mouse.Target then
            local obj = mouse.Target
            if SCAN_MODE == "Model" then obj = getFirstModel(obj) end
            currentTarget = obj; currentPathStr = getDetailedPath(obj); highlight.Adornee = obj
            local txt = analyzeHierarchy(obj, currentPathStr)
            currentDataStr, infoLabel.Text = txt:gsub("<[^>]+>", ""), txt
            updateEd(obj)
        end
    end
end)

