local function getDetailedPath(obj)
    local success, result = pcall(function()
        local pathParts = {} local current = obj
        while current and current ~= game do
            table.insert(pathParts, 1, current.Name) current = current.Parent
        end
        return "game." .. table.concat(pathParts, ".")
    end)
    return success and result or "Error"
end

local function getFirstModel(obj)
    local current = obj.Parent
    while current and current ~= workspace and current ~= game do
        if current:IsA("Model") then return current end current = current.Parent
    end
    return obj
end

