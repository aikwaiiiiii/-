            scb.Text = "-- [ Remote Selected ] --\n" .. currentSelectedRemoteCode
        else
            currentSelectedRemoteCode = "game." .. p .. ":InvokeServer(1)"
            scb.Text = "-- [ Remote Selected ] --\n" .. currentSelectedRemoteCode
        end
    end)
    rc = rc + 1
    rls.CanvasSize = UDim2.new(0, 0, 0, rc * 35)
end

