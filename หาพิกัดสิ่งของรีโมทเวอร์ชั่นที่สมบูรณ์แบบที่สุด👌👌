local rc = 0
local function addR(o)
    local b = Instance.new("TextButton", rls)
    b.Size, b.Position = UDim2.new(1, -10, 0, 25), UDim2.new(0, 5, 0, rc * 30)
    b.BackgroundColor3 = o:IsA("RemoteEvent") and Color3.fromRGB(150, 50, 80) or Color3.fromRGB(50, 80, 150)
    b.TextColor3, b.Font, b.TextSize, b.TextTruncate, b.Text = Color3.new(1, 1, 1), Enum.Font.GothamMedium, 10, Enum.TextTruncate.AtEnd, "⚡ " .. o.Name
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
    b.MouseButton1Click:Connect(function()
        local p = o:GetFullName()
        scb.Text = o:IsA("RemoteEvent") and "local a={[1]=1}\ngame." .. p .. ":FireServer(unpack(a))" or "local a={[1]=1}\nprint(game." .. p .. ":InvokeServer(unpack(a)))"
    end)
    rc = rc + 1
    rls.CanvasSize = UDim2.new(0, 0, 0, rc * 30)
end

local lR = {}
task.spawn(function()
    pcall(function()
        if hookmetamethod and getnamecallmethod and checkcaller then
            local oldNamecall
            oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(s, ...)
                local m = getnamecallmethod()
                if not checkcaller() and m == "FireServer" and s:IsA("RemoteEvent") then
                    if not lR[s] then lR[s] = true task.spawn(function() addR(s) end) end
                end
                return oldNamecall(s, ...)
            end))
        end
    end)
end)

