    rc = 0; msb.Text = "⏳..." task.wait(0.1)
    for _, o in pairs(game:GetDescendants()) do if o:IsA("RemoteEvent") or o:IsA("RemoteFunction") then addR(o) end end
    msb.Text = "🔍 SCAN"
end)
