-- Hybrid Run Logic (ฉลาดและเสถียรที่สุด)
btR.MouseButton1Click:Connect(function()
    if cbx.Text == "" then return end
    _G.ScannerAutoFarm = true
    btR.Text, btR.BackgroundColor3 = "🔄 RUNNING...", Color3.fromRGB(150, 150, 50)
    
    local txt = cbx.Text
    local isNativeFarm = string.find(txt, "AUTO%-FARM SCRIPT")
    local func = nil
    
    if not isNativeFarm then
        pcall(function() func = loadstring(txt) end)
    end
    
    task.spawn(function()
        local t, pl = tgt, lp
        while _G.ScannerAutoFarm do
            pcall(function()
                if isNativeFarm and t then
                    if t:FindFirstChildOfClass("TouchTransmitter") then
                        firetouchinterest(pl.Character.HumanoidRootPart, t, 0)
                        task.wait()
                        firetouchinterest(pl.Character.HumanoidRootPart, t, 1)
                    elseif t:FindFirstChildOfClass("ProximityPrompt") then
                        fireproximityprompt(t:FindFirstChildOfClass("ProximityPrompt"))
                    end
                elseif func then
                    func()
                end
            end)
            task.wait(0.5)
        end
    end)
end)

