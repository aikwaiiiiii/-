end)

local function gp(o)
    local s, r = pcall(function()
        local pp, c = {}, o
        while c and c ~= game do table.insert(pp, 1, c.Name); c = c.Parent end
        return "game." .. table.concat(pp, ".")
    end)
    return s and r or "Err"
end

uis.InputBegan:Connect(function(i, g)
    if g or not fr.Visible then return end
    if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
        if mouse.Target then
            local o = mouse.Target
            if mode == "Model" then
                local c = o.Parent
                while c and c ~= workspace and c ~= game do if c:IsA("Model") then o = c; break end c = c.Parent end
            end
            tgt = o; path = gp(o); hl.Adornee = o
            
            if isRecording then
                if o:FindFirstChildOfClass("TouchTransmitter") then
                    local cmd = "firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, " .. path .. ", 0) task.wait() firetouchinterest(game.Players.LocalPlayer.Character.HumanoidRootPart, " .. path .. ", 1)"
                    table.insert(recordedActions, cmd)
                elseif o:FindFirstChildOfClass("ProximityPrompt") then
                    local cmd = "fireproximityprompt(" .. path .. ":FindFirstChildOfClass('ProximityPrompt'))"
                    table.insert(recordedActions, cmd)
                end
            end
            
            local tInfo = "<font size='16' color='#00FFAA'><b>[ ข้อมูลโครงสร้างหลัก ]</b></font>\nชื่อ: " .. o.Name .. "\nประเภท: " .. o.ClassName .. "\n\n<font color='#AADDFF'>" .. path .. "</font>\n"
            if o:IsA("BasePart") then tInfo = tInfo .. "\n<font size='16' color='#00FFAA'><b>[ กายภาพ ]</b></font>\nพิกัด: " .. string.format("%.1f, %.1f, %.1f", o.Position.X, o.Position.Y, o.Position.Z) end
