-- แก้ไขระบบ Speed โดยใช้วิธีคำนวณทิศทางการเคลื่อนที่และเพิ่มแรงส่งแทนการเปลี่ยน WalkSpeed ตรงๆ
RunService.Stepped:Connect(function()
    if _G.SpeedHackToggle then
        pcall(function()
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            if hrp and hum and hum.MoveDirection.Magnitude > 0 then
                -- คำนวณและเพิ่มตำแหน่งพิกัดตามทิศทางที่ผู้เล่นกำลังบังคับเดินจริง
                local moveVelocity = hum.MoveDirection * (_G.WalkSpeedValue / 10)
                hrp.CFrame = hrp.CFrame + Vector3.new(moveVelocity.X, 0, moveVelocity.Z)
            end
        end)
    end
end)

