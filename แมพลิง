-- ระบบ Auto Q วาร์ปส่งระเบิดวิสุดท้าย
task.spawn(function()
    while true do
        task.wait(0.01)
        if _G.TigerAutoTag then
            pcall(function()
                local myChar = LocalPlayer.Character
                if myChar and myChar:FindFirstChild("HumanoidRootPart") then
                    local amIBomb = false
                    if myChar:FindFirstChild("Bomb") or myChar:FindFirstChild("Tag") or myChar:FindFirstChild("TNT") then
                        amIBomb = true
                    end
                    
                    local currentTimer = 999
                    local gui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
                    if gui then
                        for _, textLabel in pairs(gui:GetDescendants()) do
                            if textLabel:IsA("TextLabel") and textLabel.Visible and textLabel.Text:match("^%d+$") then
                                local sec = tonumber(textLabel.Text)
                                if sec and sec < currentTimer then currentTimer = sec end
                            end
                        end
                    end

                    if amIBomb and currentTimer <= _G.TargetSecToTag then
                        for _, p in pairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                                local targetHumanoid = p.Character:FindFirstChild("Humanoid")
                                if targetHumanoid and targetHumanoid.Health > 0 and not p.Character:FindFirstChild("Bomb") then
                                    local myOldPos = myChar.HumanoidRootPart.CFrame
                                    local startWarp = tick()
                                    while tick() - startWarp < 0.4 do
                                        if myChar:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("HumanoidRootPart") then
                                            myChar.HumanoidRootPart.CFrame = p.Character.HumanoidRootPart.CFrame
                                        end
                                        task.wait()
                                    end
                                    myChar.HumanoidRootPart.CFrame = myOldPos
                                    break
                                end
                            end
                        end
                        task.wait(1.5)
                    end
                end
            end)
        end
    end
end)

