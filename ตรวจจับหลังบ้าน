local function addLog(text, color)
    local LogText = Instance.new("TextBox")
    LogText.Size = UDim2.new(1, 0, 0, 22)
    LogText.BackgroundTransparency = 1
    LogText.Text = text
    LogText.TextColor3 = color or Color3.fromRGB(200, 200, 200)
    LogText.TextSize = 10
    LogText.Font = Enum.Font.Code
    LogText.TextXAlignment = Enum.TextXAlignment.Left
    LogText.ClearTextOnFocus = false
    LogText.TextEditable = false
    LogText.Parent = LogBox
end

addLog("[System]: กำลังค้นหาตำแหน่ง Module และโครงสร้างเกม...", Color3.fromRGB(0, 255, 150))

-- ทำการสแกนหาจุดเชื่อมโยงของระบบที่ใช้บนมือถือได้
pcall(function()
    local replicated = game:GetService("ReplicatedStorage")
    if replicated:FindFirstChild("Events") then
        addLog("✅ พบโฟลเดอร์หลัก: game.ReplicatedStorage.Events", Color3.fromRGB(255, 200, 50))
        for _, child in pairs(replicated.Events:GetChildren()) do
            addLog("   -> " .. child.Name .. " (" .. child.ClassName .. ")", Color3.fromRGB(230, 230, 230))
        end
    end
end)

pcall(function()
    -- ตรวจสอบโครงสร้างระบบข้อมูลผู้เล่นฝั่ง Client
    local player = game:GetService("Players").LocalPlayer
    if player:FindFirstChild("PlayerScripts") then
        addLog("🔍 ตรวจสอบระบบสคริปต์ผู้เล่น Local...", Color3.fromRGB(100, 200, 255))
        for _, v in pairs(player.PlayerScripts:GetDescendants()) do
            if v:IsA("ModuleScript") and (string.find(v.Name, "Network") or string.find(v.Name, "Controller")) then
                addLog("⭐ พบตัวควบคุม: " .. v.Name, Color3.fromRGB(255, 100, 255))
            end
        end
    end
end)
