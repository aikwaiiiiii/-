local function TeleportToRandomPlayer()
    local targetList = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then table.insert(targetList, p) end
    end
    if #targetList > 0 then
        local randomTarget = targetList[math.random(1, #targetList)]
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            LocalPlayer.Character.HumanoidRootPart.CFrame = randomTarget.Character.HumanoidRootPart.CFrame + Vector3.new(0, 2, 0)
        end
    end
end

RandTPButton.MouseButton1Click:Connect(TeleportToRandomPlayer)
