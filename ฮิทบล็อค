-- 6. ลูปคำนวณหลัก (RenderStepped Loop)
---
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if _G.SpeedEnabled then
        if hum then hum.WalkSpeed = _G.CurrentSpeed end
    else
        if hum then hum.WalkSpeed = 16 end
    end
    
    for _, plr in pairs(Players:GetPlayers()) do  
        if plr ~= LocalPlayer and plr.Character then  
            local t_hrp = plr.Character:FindFirstChild("HumanoidRootPart")  
            if t_hrp and _G.HitboxEnabled then  
                t_hrp.Size = Vector3.new(_G.HeadSize, _G.HeadSize, _G.HeadSize)  
                t_hrp.Transparency = 1  
                t_hrp.CanCollide = false  
            end  
            if _G.HighlightEnabled and not plr.Character:FindFirstChild("DebugHighlight") then  
                local Highlight = Instance.new("Highlight")  
                Highlight.Name = "DebugHighlight"  
                Highlight.FillTransparency = 0.5  
                Highlight.OutlineTransparency = 0  
                Highlight.Parent = plr.Character  
            end  
        end  
    end
end)
