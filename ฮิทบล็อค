        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") or part:IsA("Decal") then
                if part.Name ~= "HumanoidRootPart" then 
                    if _G.InvisibleEnabled then
                        SavedCharacterParts[part] = part.Transparency
                        part.Transparency = 1
                    else
                        if SavedCharacterParts[part] then part.Transparency = SavedCharacterParts[part] else part.Transparency = 0 end
                    end
                end
            end
        end
    end
end)

