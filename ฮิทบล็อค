local function CreateButton(parentWin, text, yPos)
    local Button = Instance.new("TextButton")  
    Button.Size = UDim2.new(1, -30, 0, 36)  
    Button.Position = UDim2.new(0, 15, 0, yPos)  
    Button.BackgroundColor3 = Color3.fromRGB(255, 200, 150) 
    Button.TextColor3 = Color3.fromRGB(120, 60, 10) 
    Button.Font = Enum.Font.GothamBold  
    Button.TextSize = 12  
    Button.BorderSizePixel = 0
    Button.Text = "🐾 " .. text .. " [OFF]"  
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 10)
    ButtonCorner.Parent = Button

    local BStroke = Instance.new("UIStroke")
    BStroke.Color = Color3.fromRGB(240, 140, 70)
    BStroke.Thickness = 1.5
    BStroke.Parent = Button
    
    Button.Parent = parentWin  
    return Button
end

local function ToggleVisual(state, button, baseText)
    if state then
        button.Text = "🐯 " .. baseText .. " [ON]"
        button.BackgroundColor3 = Color3.fromRGB(160, 240, 160) 
        button.TextColor3 = Color3.fromRGB(20, 80, 20)
        button.UIStroke.Color = Color3.fromRGB(100, 200, 100)
    else
        button.Text = "🐾 " .. baseText .. " [OFF]"
        button.BackgroundColor3 = Color3.fromRGB(255, 200, 150) 
        button.TextColor3 = Color3.fromRGB(120, 60, 10)
        button.UIStroke.Color = Color3.fromRGB(240, 140, 70)
    end
end

