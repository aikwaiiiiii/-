-- 5. เครื่องยนต์วิเคราะห์ข้อมูลอัจฉริยะ (The Brain - FIXED)
-- ==========================================
local function analyzeObject(obj)
    local txt = "<font color='#00FFAA'><b>[ ข้อมูลพื้นฐาน ]</b></font>\n"
    txt = txt .. "ชื่อ: " .. obj.Name .. "\n"
    txt = txt .. "ประเภท: " .. obj.ClassName .. "\n\n"

    local pathParts = {}
    local current = obj
    local isMyPlot = false
    local plotName = ""

    while current and current ~= game do
        -- [🔥 จุดที่แก้บั๊ก] ใส่ pcall กันพัง และใส่วงเล็บให้เงื่อนไขถูกต้อง
        pcall(function()
            local ownerVal = current:FindFirstChild("Owner") or current:FindFirstChild("owner")
            if ownerVal and (ownerVal:IsA("StringValue") or ownerVal:IsA("ObjectValue")) then
                local ownerName = ownerVal:IsA("StringValue") and ownerVal.Value or (ownerVal.Value and ownerVal.Value.Name)
                if ownerName == localPlayer.Name then
                    isMyPlot = true
                    plotName = current.Name
                end
            end
        end)
        
        table.insert(pathParts, 1, current.Name)
        current = current.Parent
    end
    
    currentPathStr = "game." .. table.concat(pathParts, ".")
    
    txt = txt .. "<font color='#00FFAA'><b>[ ตำแหน่งอ้างอิง (Path) ]</b></font>\n"
    txt = txt .. "<font color='#AADDFF'>" .. currentPathStr .. "</font>\n"
    if isMyPlot then
        txt = txt .. "<font color='#FFFF00'>🌟 พบว่าเป็นฐาน (Plot) ของคุณ! ("..plotName..")</font>\n"
    end
    txt = txt .. "\n"

    local interactTxt = ""
    if obj:FindFirstChildOfClass("TouchTransmitter") then interactTxt = interactTxt .. "🟢 ต้องเดินเหยียบ (TouchTransmitter)\n" end
    if obj:FindFirstChildOfClass("ClickDetector") then interactTxt = interactTxt .. "🖱️ ต้องคลิกเมาส์ (ClickDetector)\n" end
    if obj:FindFirstChildOfClass("ProximityPrompt") then interactTxt = interactTxt .. "⌨️ ต้องกดปุ่มค้าง (ProximityPrompt)\n" end
    
    if interactTxt ~= "" then
        txt = txt .. "<font color='#FF5555'><b>[ ระบบทำงานของปุ่มนี้ ]</b></font>\n" .. interactTxt .. "\n"
    end

    local hiddenValues = ""
    pcall(function()
        for _, child in ipairs(obj:GetChildren()) do
            if child:IsA("ValueBase") then
                hiddenValues = hiddenValues .. "- " .. child.Name .. ": <font color='#FFAA00'>" .. tostring(child.Value) .. "</font> ("..child.ClassName..")\n"
            end
        end
        local attrs = obj:GetAttributes()
        for k, v in pairs(attrs) do
            hiddenValues = hiddenValues .. "- [Attr] " .. k .. ": <font color='#FFAA00'>" .. tostring(v) .. "</font>\n"
        end
    end)

    if hiddenValues ~= "" then
        txt = txt .. "<font color='#FF55FF'><b>[ ตัวแปรที่ซ่อนอยู่ (Values/Attributes) ]</b></font>\n" .. hiddenValues .. "\n"
    end

    if obj:IsA("BasePart") then
        txt = txt .. "<font color='#00FFAA'><b>[ ข้อมูลกายภาพ ]</b></font>\n"
        txt = txt .. "CanCollide: " .. tostring(obj.CanCollide) .. " | Anchored: " .. tostring(obj.Anchored) .. "\n"
    end

    return txt
end

local function getFirstModel(obj)
    local current = obj.Parent
    while current and current ~= workspace and current ~= game do
        if current:IsA("Model") then return current end
        current = current.Parent
    end
    return obj
end

