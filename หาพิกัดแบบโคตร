local function copyToClipboard(text, btnElement)
    if setclipboard then
        setclipboard(text)
        local oldText = btnElement.Text
        btnElement.Text = "Copied!"
        task.wait(1.5)
        btnElement.Text = oldText
    else
        local oldText = btnElement.Text
        btnElement.Text = "Failed!"
        task.wait(1.5)
        btnElement.Text = oldText
    end
end

