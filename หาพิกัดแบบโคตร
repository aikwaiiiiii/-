-- 6. ระบบแตะหน้าจอ (Touch & Click)
-- ==========================================
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe or not frame.Visible then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if mouse.Target then
            local obj = mouse.Target
            if SCAN_MODE == "Model" then obj = getFirstModel(obj) end
            
            currentTarget = obj
            
            local partCount = 0
            for _, child in ipairs(obj:GetDescendants()) do
                if child:IsA("BasePart") then partCount = partCount + 1 end
                if partCount > 1000 then break end
            end
            
            -- ครอบ pcall ป้องกันไม่ให้แครชเวลาเจอวัตถุแปลกๆ
            local success, txt = pcall(function() return analyzeObject(obj) end)
            if not success then
                txt = "⚠️ เกิดข้อผิดพลาดในการอ่านข้อมูลวัตถุนี้\nError: " .. tostring(txt)
            end
            
            if partCount > 1000 then
                highlight.Adornee = nil
                txt = txt .. "\n<font color='#FF4444'><b>⚠️ ปิดไฮไลต์:</b> วัตถุมีขนาดใหญ่เกินไปเพื่อป้องกันเกมค้าง</font>"
            else
                highlight.Adornee = obj
            end

            currentDataStr = txt:gsub("<[^>]+>", "")
            infoLabel.Text = txt
        end
    end
end)

